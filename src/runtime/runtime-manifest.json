{
  "name": "catpaw-runtime",
  "version": "3.0.1",
  "runtimePath": "~/.catpaw",
  "boardSchemaVersion": 2,
  "released": "2026-07-13",
  "canonicalFiles": [
    "VERSION",
    "runtime-manifest.json",
    "README.md",
    "AI-INSTALL.md",
    "CHANGELOG.md",
    "runtime-policy.md",
    "bin/",
    "guidance/",
    "lenses/",
    "lib/",
    "migrations/",
    "providers/",
    "schemas/",
    "snippets/",
    "templates/"
  ],
  "cli": {
    "entrypoint": "bin/catpaw.mjs",
    "commands": [
      "board init|status|doctor|migrate",
      "work start|close",
      "milestone start|add|close",
      "evidence add",
      "agent check|open|send|status|read|close"
    ]
  },
  "projectArtifactPath": ".catpaw",
  "legacyRuntimePaths": []
}
